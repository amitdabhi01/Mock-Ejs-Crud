<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Users</title>
</head>

<body>
    <div class="container">
        <form action="/add" method="post">
            <h1><label for="">Add image</label></h1>
            <br>
            <br>
            <input type="text" placeholder="enter image url" name="image" required>


            <br>
            <br>

            <h1><label for="">Add User Name</label></h1>
            <br>
            <br>
            <input type="text" placeholder="Enter Name" name="name" required>

            <br>
            <br>

            <h1><label for="">Add User email</label></h1>
            <br>
            <br>
            <input type="email" placeholder="enter user email" name="email" required>
            <br />
            <br />
            <h1><label for="">Add User phone</label></h1>
            <br>
            <br>
            <input type="number" placeholder="enter user phone" name="phone" required>

            <button type="submit">Add</button>
        </form>
    </div>
</body>

</html>